# Root example only. Do not put real secrets in GitHub.

# Frontend public variables
NEXT_PUBLIC_APP_URL=https://your-domain.com
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
NEXT_PUBLIC_API_BASE_URL=https://your-backend-api.onrender.com

# Backend private variables
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-never-expose-in-frontend
DATABASE_URL=postgresql://postgres:password@db.your-project.supabase.co:5432/postgres
JWT_SECRET=replace-with-long-random-secret
ALLOWED_ORIGINS=https://your-domain.com,https://your-vercel-project.vercel.app

# Storage buckets
SUPABASE_BUCKET_STUDENT_DOCUMENTS=student-documents
SUPABASE_BUCKET_UNIVERSITY_MEDIA=university-media
SUPABASE_BUCKET_BROCHURES=university-brochures
